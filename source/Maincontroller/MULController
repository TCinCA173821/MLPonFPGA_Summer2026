module MULcontroller (
    input logic clk,
    input logic n_rst,
    input logic mulstart,
    input logic [9:0] iter1,
    input logic [9:0] iter2,
    input logic state, // basically 0 for hl and 1 for ol
    input logic MAC_dv,
    input logic dDv, // is input data valid
    output logic DV,
    output logic input_sel, // select where to draw info from spi or both
    output logic MAC_str // start signal for MAC
);

    typedef enum logic [2:0] { 
        IDLE,
        PULLBIAS,
        LOADBIAS,
        PULLINPUT,
        COMPUTE,
        COMPUTEDONE
     } state_t;

    state_t curstate, nxtstate; 
    logic [9:0] count, nxtcount;
    
    
    always_ff @ (posedge clk, negedge n_rst) begin // state register
        if(!n_rst) begin 
            curstate <= IDLE;
            count <= '0;
        end
        else begin
            curstate <= nxtstate;
            count <= nxtcount;
        end
    end

    always_comb begin
        case(curstate)
            IDLE: nxtstate = mulstart ? PULLBIAS : IDLE;
            PULLBIAS: nxtstate = dDv ? LOADBIAS : PULLBIAS;
            LOADBIAS: nxtstate = PULLINPUT;
            PULLINPUT: nxtstate = dDv ? COMPUTE : PULLINPUT;
            COMPUTE: nxtstate = MAC_dv ? COMPUTEDONE : COMPUTE;
            COMPUTEDONE: nxtstate = (state ? iter2 : iter1) == count ? IDLE : PULLINPUT;
            default: nxtstate = IDLE;
        endcase
    end

    always_comb begin
        DV = 'd0;
        MAC_str = 'd0;
        nxtcount = count;
        case(curstate)
            IDLE: DV = 'd1;
            COMPUTE: begin 
                MAC_str = 'd1;
                nxtcout = MAC_dv ? count + 'd1 : count;
            end
        endcase
    end
    assign input_sel = state;
endmodule