module main_controller(
    input logic clk,
    input logic n_rst,
    input logic start,
    input logic HLd,
    input logic OLd,
    input logic ARGd,
    output logic HLen,
    output logic OLen,
    output logic ARGen,
    output logic state,
    output logic infdone
);

    typedef enum logic [1:0] { 
        IDLE = 2'd0,
        HIDDEN_LAYER = 2'd1,
        OUTPUT_LAYER = 2'd2,
        ARGMAX = 2'd3
     } state_t;

     state_t curstate, nxtstate;
     logic HLen, OLen, ARGen; // enable signals for the sub controllers
     logic HLd, OLd, ARGd; // done signals  from the sub subcontrollers


     always_ff @ (posedge clk, negedge n_rst) begin // state register for topmost controller
        if (!n_rst) begin
            curstate <= IDLE;
        end else begin
            curstate <= nxtstate;
        end
     end

     always_comb begin // next state logic for topmost controller
        case(curstate)
            IDLE: nxtstate = start ? HIDDEN_LAYER : IDLE;
            HIDDEN_LAYER: nxtstate = HLd ? OUTPUT_LAYER : HIDDEN_LAYER;
            OUTPUT_LAYER: nxtstate = OLd ? ARGMAX : OUTPUT_LAYER;
            ARGMAX: nxtstate = ARGd ? IDLE : ARGMAX;
            default: nxtstate = IDLE;
        endcase
     end
    
    always_comb begin // output logic for main submodule enables from topmost controller
        HLen = 'd0;
        OLen = 'd0;
        ARGen = 'd0;
        state = 'd0;
        infdone = 'd0;
        case(curstate) 
            IDLE: infdone = 'd1;
            HIDDEN_LAYER: HLen = 'd1;
            OUTPUT_LAYER: begin
                OLen = 'd1;
                state = 'd1;
            end
            ARGMAX: ARGen = 'd1;
        endcase
    end

endmodule


